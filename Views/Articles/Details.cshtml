@model ArticleViewModel

<h1>Detalii Articol</h1>

<div class="card shadow-sm p-4">
    <h2>@Model.Title</h2>
    <hr />
    <p><strong>Categorie:</strong> @Model.CategoryName</p>
    <p><strong>Autor:</strong> @Model.AuthorName</p>
    <p><strong>Data Publicării:</strong> @Model.PublishedAt.ToLongDateString()</p>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="mb-3 text-center">
            <img src="@Model.ImagePath" alt="Imagine Articol" class="img-fluid rounded" style="max-height: 400px;" />
        </div>
    }

    <div class="mt-3" style="white-space: pre-line;">
        @Model.Content
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editează</a> |
    <a asp-action="Index" class="btn btn-secondary">Înapoi la listă</a>
</div>