@model List<Lab06.ViewModels.ArticleViewModel>

<div class="d-flex justify-content-between align-items-center">
    <h1>Toate Articolele</h1>
    @* Butonul de adăugare articol *@
    <a asp-action="Create" class="btn btn-success">Adaugă Articol Nou</a>
</div>

<hr />

<div>
    @foreach (var article in Model)
    {
        <div class="mb-4 p-3 border rounded shadow-sm">
            <h3>@article.Title</h3>
            <p class="text-muted small">Categorie: @article.CategoryName | Autor: @article.AuthorName</p>
            <p>@article.Content</p>

            @* Aici sunt butoanele de acțiune care îți lipseau *@
            <div class="mt-2">
                <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Details" asp-route-id="@article.Id" class="btn btn-sm btn-info text-white">Detalii</a>
                <a asp-action="Delete" asp-route-id="@article.Id" class="btn btn-sm btn-danger">Șterge</a>
            </div>
        </div>
    }
</div>

<div class="mt-4 d-flex align-items-center">
    @if (ViewBag.CurrentPage > 1)
    {
        <a class="btn btn-secondary me-2" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">Înapoi</a>
    }

    <span class="mx-3">Pagina @ViewBag.CurrentPage din @ViewBag.TotalPages</span>

    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a class="btn btn-primary ms-2" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">Următorul</a>
    }
</div>