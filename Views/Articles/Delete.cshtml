@model ArticleViewModel
<h1>Ștergere articol</h1>
<p>Sigur doriti sa stergeti acest articol?</p>
<div>
    <h3>@Model.Title</h3>
    <p><strong>Category:</strong> @Model.CategoryName</p>
    <p>
        <strong>Data:</strong>
        @Model.PublishedAt.ToShortDateString()
    </p>
    <p>@Model.Content</p>
</div>
<form method="post">
    <button type="submit" class="btn btn-danger">Confirma stergerea</button>
</form>
<a asp-page="/Index">← Inapoi la lista</a>